# Prototype Federated Learning (PFL) Configuration

# Federated Learning Setup
NUM_CLIENTS=10
NUM_ROUNDS=2

# Data Splitting
ALPHA=0.1
SEED=42

# Training Hyperparameters
EPOCHS=10
LAMBDA_P=0.01
USE_CLASS_WEIGHTS=0
TRAIN_BACKBONE=1
TRAIN_HEAD=1
MAX_SAMPLES_PER_CLIENT=0

# Hardware override (empty string allows auto-detect, or 'cuda', 'cpu', 'mps')
DEVICE=
RAY_NUM_GPUS=0.2

# Logging and Security
PROGRESS=0
SECURITY_LOGGING=1
SNAPSHOT_DIR=outputs/security/snapshots